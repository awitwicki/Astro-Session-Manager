{
  "name": "astro-session-manager",
  "version": "1.0.2",
  "description": "Astrophotography session manager - manage imaging sessions, FITS files, and masters library",
  "main": "./out/main/index.js",
  "author": "awitwicki",
  "license": "GNU GENERAL PUBLIC LICENSE",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "node scripts/install-sharp-platform.js win32 x64 && electron-vite build && electron-builder --win",
    "package:linux": "node scripts/install-sharp-platform.js linux x64 && electron-vite build && electron-builder --linux",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.33.5",
    "@img/sharp-darwin-x64": "^0.33.5",
    "@img/sharp-linux-x64": "^0.33.5",
    "@img/sharp-win32-x64": "^0.33.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-store": "^10.0.0",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "typescript": "~5.7.3",
    "vite": "^6.0.7",
    "zustand": "^5.0.3"
  }
}
